  <diagram name="Oldal-1" id="eSApZaN4mGQcwWIf6OvF">
    <mxGraphModel dx="1216" dy="704" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>

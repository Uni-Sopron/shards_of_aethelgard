        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam class {\n    BackgroundColor White\n    ArrowColor Black\n    BorderColor DarkSlateGray\n}\n\n&#39; --- ENUMOK ---\nenum KasztTipus {\n    RunaHarcos\n    SzamMagus\n    ArnyekAlgoritmus\n}\n\n&#39; --- KARAKTER HIERARCHIA ---\nabstract class Karakter {\n    - nev: string\n    - hp: int\n    - maxHp: int\n    - tamadoEro: int\n    - vedekezes: int\n    - sebesseg: int\n    + SebzestSzenved(ertek: int): void\n    + HalottE(): bool\n    + Tamadas(celpont: Karakter, mod: int): int\n}\n\nclass Jatekos {\n    - tapasztalatiPont: int\n    - szint: int\n    - kaszt: KasztTipus\n    + SzintLepes(): void\n    + XpSzerzes(ertek: int): void\n    + TamadasiModokLekerdezese(): List&lt;string&gt;\n}\n\nclass Ellenfel {\n    - isFoboss: bool\n    + AutomataLepes(): int\n}\n\nKarakter &lt;|-- Jatekos\nKarakter &lt;|-- Ellenfel\n\n&#39; --- KÜLDETÉS HIERARCHIA ---\nabstract class Kuldetes {\n    - id: int\n    - leiras: string\n    - teljesitve: bool\n    + KuldetesInditasa(): void\n    + TeljesitveE(): bool\n}\n\nclass HarciKuldetes {\n    - ellenfel: Ellenfel\n    - korokSzama: int\n    - elszenvedettSebzes: int\n    + HarcKezdese(j: Jatekos, autoHarc: bool): void\n    + XpKalkulacio(): int\n}\n\nclass FejtoroKuldetes {\n    - feladvanySzoveg: string\n    - vartValasz: double\n    - turesHatar: double\n    + ValaszEllenorzese(valasz: double): bool\n    + MegoldasKadasa(valasz: double): int\n}\n\nKuldetes &lt;|-- HarciKuldetes\nKuldetes &lt;|-- FejtoroKuldetes\nHarciKuldetes o-- Ellenfel : tartalmaz\n\n&#39; --- JÁTÉKMENEDZSMENT ---\nclass JatekMenedzser {\n    - aktualisJatekos: Jatekos\n    - kuldetesek: List&lt;Kuldetes&gt;\n    - aktualisKuldetesIndex: int\n    + UjJatek(nev: string, kaszt: KasztTipus): void\n    + JatekMentes(): void\n    + JatekBetoltes(): void\n    + KovetkezoKuldetes(): void\n}\n\nclass MentesKezelo {\n    - fajlNev: string\n    + AdatMentese(j: Jatekos, k: List&lt;Kuldetes&gt;): bool\n    + AdatBetoltese(): Jatekos\n}\n\nJatekMenedzser *-- Jatekos : kezeli\nJatekMenedzser *-- Kuldetes : irányítja\nJatekMenedzser ..&gt; MentesKezelo : használja\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Dj0w7_uMpYHHf68fPc_2-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
